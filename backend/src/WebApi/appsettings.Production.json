{
  "ConnectionStrings": {
    "DefaultConnection": "Host=DB_HOST;Database=visualization_dsa_prod;Username=DB_USER;Password=DB_PASSWORD"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_SECURE_32_CHAR_KEY_IN_ENV_VARIABLE",
    "Issuer": "VisualizationDSA",
    "Audience": "VisualizationDSA-Client"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-production-domain.com",
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Error",
        "VisualizationDSA": "Information"
      }
    }
  }
}
